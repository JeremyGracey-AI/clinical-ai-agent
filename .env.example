# ---- FHIR / SMART on FHIR ----
# Public HAPI R4 sandbox works with NO auth out of the box.
FHIR_BASE_URL=https://hapi.fhir.org/baseR4
SMART_CLIENT_ID=
SMART_REDIRECT_URI=http://localhost:7860/callback
SMART_SCOPES=launch patient/Patient.r patient/Observation.rs patient/Observation.c openid fhirUser

# ---- LLM (optional) ----
# Leave blank to run in OFFLINE mode with the deterministic stub LLM.
LLM_PROVIDER=stub            # stub | openai | anthropic
LLM_MODEL=gpt-4o-mini        # used when LLM_PROVIDER=openai
ANTHROPIC_MODEL=claude-haiku-4-5-20251001  # used when LLM_PROVIDER=anthropic
LLM_TEMPERATURE=0            # clinical determinism: always 0
LLM_MAX_TOKENS=1024
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- RAG ----
# Leave blank to run in OFFLINE mode with the hashing embedder + in-memory index.
EMBED_PROVIDER=stub          # stub | sentence-transformers
EMBED_MODEL=all-MiniLM-L6-v2
USE_CHROMA=false             # true -> persist/retrieve via ChromaDB (needs [full])
CHROMA_DIR=./data/chroma
CORPUS_DIR=./data/corpus
RETRIEVAL_TOP_K=4
RETRIEVAL_MIN_SCORE=0.15
RETRIEVAL_REFINE=true        # re-query once if nothing clears the confidence floor

# ---- Evaluation / analytics ----
JUDGE_FAITHFULNESS=false     # true -> LLM-as-judge faithfulness (needs a real LLM)
ANALYTICS_PATH=./data/analytics.jsonl
PROFILE_PATH=./data/learner_profile.json
